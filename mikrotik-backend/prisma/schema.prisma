generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  username  String   @unique // (ใช้ชื่อหน้า @ ของ email)
  password  String
  role      UserRole @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  isArchived Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs           ActivityLog[]
  configs        Config[]
  managedDevices ManagedDevice[]
  articles       Article[]
  favoriteArticles FavoriteArticle[]
  comments       Comment[]
}

model DeviceModel {
  id       Int            @id @default(autoincrement())
  name     String         @unique
  imageUrl String?
  isActive Boolean        @default(true)
  configs  Config[]
  ports    PortTemplate[]
}

model PortTemplate {
  id            Int         @id @default(autoincrement())
  name          String
  type          PortType    @default(ETHER)
  defaultRole   String?
  deviceModelId Int
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id], onDelete: Cascade)

  @@index([deviceModelId], map: "PortTemplate_deviceModelId_fkey")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text // เก็บข้อมูลเป็น JSON String
  description String? // สำหรับแสดงคำอธิบายในหน้า UI ให้ Admin เข้าใจง่ายขึ้น
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Config {
  id              Int    @id @default(autoincrement())
  projectName     String
  inputData       Json
  generatedScript String @db.Text

  // ✅ เชื่อมโยงกับ ManagedDevice (สำคัญสำหรับการเปลี่ยน Model)
  managedDeviceId Int?
  managedDevice   ManagedDevice? @relation(fields: [managedDeviceId], references: [id], onDelete: SetNull)

  // ยังคงเก็บ Model ไว้ เพื่อให้รู้ว่าประวัตินี้ใช้กับรุ่นไหน
  deviceModelId Int
  deviceModel   DeviceModel @relation(fields: [deviceModelId], references: [id])

  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([managedDeviceId])
  @@index([deviceModelId], map: "Config_deviceModelId_fkey")
  @@index([userId], map: "Config_userId_fkey")
}

model ActivityLog {
  id        Int        @id @default(autoincrement())
  userId    Int
  action    ActionType
  details   String?
  ipAddress String?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])

  @@index([userId], map: "ActivityLog_userId_fkey")
  @@index([createdAt])
  @@index([action])
}

// ✅ 1. เพิ่มตาราง DeviceEventLog สำหรับเก็บประวัติการเปลี่ยนสถานะ
model DeviceEventLog {
  id       Int           @id @default(autoincrement())
  deviceId Int // ใช้ Int ให้ตรงกับ id ของ ManagedDevice
  device   ManagedDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  eventType String // เก็บค่า: 'UP', 'DOWN', 'WARNING', 'ACK'
  details   String? // เก็บรายละเอียด เช่น "CPU: 99%, RAM: 80%" หรือ "Device is back online"
  createdAt DateTime @default(now())

  @@index([deviceId]) // ทำ Index เพื่อให้ค้นหาประวัติของอุปกรณ์แต่ละตัวได้เร็วขึ้น
  @@index([createdAt])
}

// ==========================================
// Device Group & Notification Settings (เพิ่มใหม่)
// ==========================================
model DeviceGroup {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  adminName        String?
  adminContact     String? 
  description String?

  // Telegram Bot Settings สำหรับกลุ่มนี้โดยเฉพาะ
  telegramBotToken String?
  telegramChatId   String?
  isNotifyEnabled  Boolean @default(true) // เปิด/ปิด การแจ้งเตือนของกลุ่มนี้

  // AI Settings สำหรับกลุ่มนี้
  aiEnabled         Boolean  @default(false)
  aiGeminiKey       String?
  aiSystemPrompt    String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ความสัมพันธ์ (Many-to-Many) กับอุปกรณ์
  devices ManagedDevice[]
}

model ManagedDevice {
  id         Int       @id @default(autoincrement())
  name       String
  circuitId  String?
  apiToken   String    @unique @default(uuid())
  currentIp  String    @default("127.0.0.1")
  ddnsName  String?
  lastSeen   DateTime?
  pendingCmd String?
  configData Json?

  // Monitoring Fields
  status      String  @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED
  cpuLoad     Int?    @default(0)
  memoryUsage Int?    @default(0)
  uptime      String?
  version     String?
  boardName   String?

  storage Int?    @default(0)
  temp    String?
  latency String?

  //สำหรับระบบหน่วงเวลาแจ้งเตือน (Flap Detection)
  warningStartedAt DateTime? // เวลาที่เริ่มพบปัญหา
  isWarningAlerted Boolean   @default(false) // เตือนเรื่องโหลดหนักไปแล้วหรือยัง
  isOfflineAlerted Boolean   @default(false) // เตือนเรื่องออฟไลน์ไปแล้วหรือยัง
  lastAlertMessageIds Json?

  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  // Acknowledge System
  isAcknowledged Boolean   @default(false)
  ackReason      Json?
  ackByUserId    Int?
  ackAt          DateTime?

  configHistory Config[]
  eventLogs DeviceEventLog[]
  groups DeviceGroup[]

  @@index([userId], map: "ManagedDevice_userId_fkey")
}

model Article {
  id          Int            @id @default(autoincrement())
  title       String
  slug        String         @unique
  content     String         @db.LongText
  excerpt     String?        @db.Text
  thumbnail   String?        @db.Text
  
  categoryId  Int?
  category    ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  tags        ArticleTag[]
  
  status      ArticleStatus     @default(DRAFT)
  visibility  ArticleVisibility @default(PUBLIC)
  isPinned    Boolean           @default(false)
  viewCount   Int               @default(0)
  authorId    Int
  author      User              @relation(fields: [authorId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  images      ArticleImage[]
  videos      ArticleVideo[]
  attachments ArticleAttachment[]
  favoritedBy FavoriteArticle[]
  comments    Comment[]

  @@index([authorId])
  @@index([categoryId])
}

model ArticleVideo {
  id        Int      @id @default(autoincrement())
  url       String   @db.Text
  filename  String
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([articleId])
}

model ArticleAttachment {
  id            Int      @id @default(autoincrement())
  filename      String   // Original name
  storageName   String   // Unique name on disk
  fileSize      Int
  fileExt       String
  downloadCount Int      @default(0)
  isVisible     Boolean  @default(true)
  
  articleId     Int
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([articleId])
}

model FavoriteArticle {
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, articleId])
  @@index([articleId])
  @@index([userId])
}

model ArticleCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  slug        String    @unique
  description String?
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ArticleTag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  articles  Article[]
  createdAt DateTime  @default(now())
}

model ArticleImage {
  id        Int      @id @default(autoincrement())
  url       String   @db.Text
  filename  String
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([articleId])
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum ArticleVisibility {
  PUBLIC
  EMPLOYEE
  ADMIN
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
  GUEST
}

enum PortType {
  ETHER
  SFP
  WLAN
}

enum ActionType {
  LOGIN
  LOGIN_FAIL
  LOGOUT
  CREATE_DEVICE
  UPDATE_DEVICE
  DELETE_DEVICE
  ACKNOWLEDGE_DEVICE
  GENERATE_CONFIG
  GENERATE_VPN
  CREATE_GROUP
  UPDATE_GROUP
  DELETE_GROUP
  MANAGE_GROUP_DEVICES
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  TOGGLE_USER_STATUS
  UPDATE_SETTING
  CREATE_MODEL
  UPDATE_MODEL
  DELETE_MODEL
  CREATE_ARTICLE
  UPDATE_ARTICLE
  DELETE_ARTICLE
  UPLOAD_ARTICLE_IMAGE
  UPLOAD_ARTICLE_VIDEO
  CREATE_CATEGORY
  UPDATE_CATEGORY
  DELETE_CATEGORY
  CREATE_TAG
  DELETE_TAG
  CREATE_COMMENT
  DELETE_COMMENT
}

model RevokedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime // เก็บเวลาหมดอายุ เพื่อให้เราเขียนระบบลบข้อมูลขยะทิ้งได้
  createdAt DateTime @default(now())

  @@index([expiresAt]) // ทำ Index เพื่อให้ค้นหาและลบได้เร็วขึ้น
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  
  articleId Int
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // สำหรับระบบ Reply (Threaded Comments)
  parentId  Int?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
}
